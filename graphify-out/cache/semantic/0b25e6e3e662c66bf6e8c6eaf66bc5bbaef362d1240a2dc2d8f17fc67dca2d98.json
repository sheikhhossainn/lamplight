{"nodes": [{"id": "roadmap", "label": "ROADMAP.md (product roadmap)", "file_type": "document", "source_file": "ROADMAP.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "roadmap_phasing_philosophy", "label": "Phasing philosophy: ship smallest thing, additive-only schema", "file_type": "rationale", "source_file": "ROADMAP.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Ship the smallest thing that lets 10-15 friends read and lets you measure what they do, before building Premium; Premium-shaped schema exists so adding features later is additive, never a risky migration."}, {"id": "roadmap_free_tier_philosophy", "label": "Free-tier philosophy: caps generous, not stingy", "file_type": "rationale", "source_file": "ROADMAP.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A cap that bites too early kills the habit before it forms; caps should sit above what a normal engaged reader hits in 2-4 weeks so the wall only appears once someone is already dependent, making 'go unlimited' read as relief. translations_per_day is a daily rate limit (not a collection cap) and is set more generously since it's most likely to interrupt an immersive session."}, {"id": "roadmap_evernote_sync_limit_example", "label": "Evernote 2-device sync limit (cautionary example)", "file_type": "concept", "source_file": "ROADMAP.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "roadmap_duolingo_free_model_example", "label": "Duolingo unlimited-core-lessons model (model to copy)", "file_type": "concept", "source_file": "ROADMAP.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "roadmap_phase_0_alpha", "label": "Phase 0 -- Alpha: 10-15 friend beta", "file_type": "c