{"nodes": [{"id": "roadmap_phasing_philosophy", "label": "Phasing philosophy", "file_type": "rationale", "source_file": "ROADMAP.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Ship the smallest thing that lets 10-15 friends actually read and lets you measure what they do before building any Premium feature; Premium-shaped schema fields exist so later features are additive, never a risky migration."}, {"id": "roadmap_free_tier_philosophy", "label": "Free tier philosophy \u2014 why caps are generous", "file_type": "rationale", "source_file": "ROADMAP.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Caps should sit above what a normal engaged reader hits in 2-4 weeks so a real habit forms before any wall appears \u2014 citing Evernote's 2-device sync limit as the cautionary tale and Duolingo's unlimited-core-lessons model as the one to copy. translations_per_day is set more generously than the per-book caps because it's a daily rate limit most likely to interrupt an immersive session and break first-session trust."}, {"id": "roadmap_phase_0_alpha", "label": "Phase 0 \u2014 Alpha: the 10-15 friend beta", "file_type": "concept", "source_file": "ROADMAP.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "roadmap_phase_1_premium_v1", "label": "Phase 1 \u2014 Premium, v1", "file_type": "concept", "source_file": "ROADMAP.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "roadmap_phase_2_ai_companion", "label": "Phase 2 \u2014 AI Reading Companion", "file_type": "concept", "source_file": "ROADMAP.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "roadmap_premium_message", "label": "The Premium message", "file_type": "rationale", "source_file": "ROADMAP.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Don't market Premium as 'unlimited translations' \u2014 market it as helping you remember what you read; vocabulary, quotes, SRS, and insights all serve that one pitch."}, {"id": "roadmap_schema_to_feature_map", "label": "Schema-to-feature map", "file_type": "document", "source_file": "ROADMAP.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "roadmap_context_aware_translation", "label": "Context-Aware Translation (Premium)", "file_type": "concept", "source_file": "ROADMAP.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "roadmap_smart_learning", "label": "Smart Learning (SRS, adaptive quizzes, mastery)", "file_type": "concept", "source_file": "ROADMAP.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "roadmap_reading_insights", "label": "Reading Insights", "file_type": "concept", "source_file": "ROADMAP.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "roadmap_premium_reading_atmosphere", "label": "Premium reading atmosphere (full ambient set)", "file_type": "concept", "source_file": "ROADMAP.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "roadmap_cloud_features", "label": "Cloud features (backup, cross-device sync)", "file_type": "concept", "source_file": "ROADMAP.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "roadmap_billing", "label": "Billing (subscriptions table + provider)", "file_type": "concept", "source_file": "ROADMAP.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null