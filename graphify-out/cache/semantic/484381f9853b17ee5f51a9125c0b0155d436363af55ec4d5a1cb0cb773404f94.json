{"nodes": [{"id": "context_lamplight", "label": "Lamplight App", "file_type": "document", "source_file": "context.md", "source_location": "L1", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "context_build_plan", "label": "Full Build Plan (floating-noodling-metcalfe.md)", "file_type": "document", "source_file": "context.md", "source_location": "L9", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "context_react_native_expo", "label": "React Native + Expo SDK 54 Stack", "file_type": "rationale", "source_file": "context.md", "source_location": "L13", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Chosen over an earlier Kotlin Multiplatform + Compose Multiplatform plan because the user's dev environment is VS Code, not Android Studio/IntelliJ; RN+Expo has first-class VS Code support and Expo Go lets you iterate on a physical phone with near-zero native setup."}, {"id": "context_kotlin_multiplatform", "label": "Kotlin Multiplatform + Compose Multiplatform (rejected plan)", "file_type": "rationale", "source_file": "context.md", "source_location": "L14", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Earlier plan, rejected because CMP's tooling assumes a JetBrains IDE, incompatible with the user's VS Code environment."}, {"id": "context_expo_go", "label": "Expo Go (no custom Dev Client)", "file_type": "concept", "source_file": "context.md", "source_location": "L15", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "context_expo_router", "label": "Expo Router (file-based, src/app/)", "file_type": "concept", "source_file": "context.md", "source_location": "L13", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "context_sdk_pinning", "label": "SDK Version Pinning (SDK 54)", "file_type": "rationale", "source_file": "context.md", "source_location": "L17-L26", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Pinned to Expo SDK 54 because that's what the phone's Expo Go build supported when this was set up; a mismatched SDK causes 'Incompatible SDK version' at launch, fixed by updating Expo Go or re-pinning via expo install --fix."}, {"id": "context_expo_router_hot_reload_gotcha", "label": "Expo Router Hot-Reload Gotcha", "file_type": "rationale", "source_file": "context.md", "source_location": "L28-L30", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Deleting/adding/restructuring route files does not reliably hot-reload; fix is to stop Metro and restart with npx expo start -c, then reopen Expo Go on the phone."}, {"id": "context_design_system", "label": "Design System (tokens.ts + typography.ts)", "file_type": "rationale", "source_file": "context.md", "source_location": "L32-L34", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Locked design system, transcribed directly from the Figma Design System doc; not arbitrary, do not tweak ad hoc."}, {"id": "context_color_palette", "label": "Color Palette (Flame Amber, Parchment, Primary Dark)", "file_type": "concept", "source_file": "context.md", "source_location": "L36", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "context_typography", "label": "Typography (Lora/Manrope, 1.85 line-height)", "file_type": "concept", "source_file": "context.md", "source_location": "L37", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "context_fold_flame_motif", "label": "Fold/Flame Motif", "file_type": "concept", "source_file": "context.md", "source_location": "L38", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "context_flameglow", "label": "FlameGlow.tsx Brand Mark", "file_type": "rationale", "source_file": "context.md", "source_location": "L39", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Only a glow layer behind the logo pulses opacity; the mark itself stays fully static/opaque. Earlier version scaled+rotated the flame and dipped its opacity to 0, which looked like distortion/glitching \u2014 don't reintroduce that."}, {"id": "context_architecture", "label": "Project Architecture (src/ layout)", "file_type": "concept", "source_file": "context.md", "source_location": "L41-L64", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "context_db_layer", "label": "SQLite Data Layer (db/)", "file_type": "concept", "source_file": "context.md", "source_location": "L68-L70", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "context_content_ingestion", "label": "Content Ingestion Feature (catalog.ts)", "file_type": "concept", "source_file": "context.md", "source_location": "L56", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "context_reader_engine", "label": "Reader Engine (features/reader)", "file_type": "concept", "source_file": "context.md", "source_location": "L86-L95", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "context_translation_feature", "label": "Translation Feature (features/translation)", "file_type": "concept", "source_file": "context.md", "source_location": "L96-L98", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "context_subscription_feature", "label": "Subscription Feature (isPremiumUser stub)", "file_type": "concept", "source_file": "context.md", "source_location": "L59", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "context_ingest_books_script", "label": "scripts/ingest-books.mjs", "file_type": "code", "source_file": "context.md", "source_location": "L72-L84", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "context_gutendex", "label": "Gutendex API", "file_type": "concept", "source_file": "context.md", "source_location": "L74", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "context_project_gutenberg", "label": "Project Gutenberg", "file_type": "concept", "source_file": "context.md", "source_location": "L74", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "context_strip_leading_toc", "label": "stripLeadingToc() Heuristic", "file_type": "rationale", "source_file": "context.md", "source_location": "L80", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Detects a run of >=3 suspiciously tightly-packed chapter-heading matches at the start of the text and drops the whole run, since duplicate TOC entries cluster far more tightly than any real chapter body, regardless of book length \u2014 this generalizes across books."}, {"id": "context_chapter1_anchor", "label": "chapter1Anchor Override (Pride and Prejudice)", "file_type": "rationale", "source_file": "context.md", "source_location": "L81", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Only pride-and-prejudice needs an explicit chapter1Anchor because that Gutenberg edition's real Chapter 1 has no heading and sits after a critic's introduction essay. A generic 'paragraph length' heuristic was tried and reverted because it can't distinguish a real unheaded chapter 1 from a long editorial introduction."}, {"id": "context_book_catalog", "label": "BOOK_CATALOG / catalog.ts", "file_type": "code", "source_file": "context.md", "source_location": "L83", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "context_paginate", "label": "paginate.ts Pagination Engine", "file_type": "rationale", "source_file": "context.md", "source_location": "L88", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Chapters are pre-chunked at ingestion time by character budget rather than measured against actual on-device rendered glyph layout \u2014 a pragmatic simplification versus the more-correct, much-harder real per-device text measurement approach."}, {"id": "context_reader_mode_enum", "label": "ReaderMode Enum (Day / Lamp default / Lamp alt)", "file_type": "concept", "source_file": "context.md", "source_location": "L89-L92", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "context_lampglowoverlay", "label": "LampGlowOverlay Component", "file_type": "concept", "source_file": "context.md", "source_location": "L91", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "context_warmthpicker", "label": "WarmthPicker Component", "file_type": "rationale", "source_file": "context.md", "source_location": "L91", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A discrete 5-preset picker rather than a continuous drag slider \u2014 a pragmatic simplification."}, {"id": "context_readerpageview", "label": "ReaderPageView.tsx + words.ts Tokenizer", "file_type": "concept", "source_file": "context.md", "source_location": "L93", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "context_highlight_feature", "label": "Highlight Feature (paragraph-level long-press)", "file_type": "rationale", "source_file": "context.md", "source_location": "L93", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Long-press a paragraph rather than arbitrary text-range selection \u2014 a deliberate scope cut. The highlights table's start_offset/end_offset columns are repurposed to hold the paragraph index, not a character offset, when read back in the Reader."}, {"id": "context_pageturnflash", "label": "PageTurnFlash.tsx Transition", "file_type": "rationale", "source_file": "context.md", "source_location": "L94", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A brief amber corner flash, not a 3D page-flip simulation, matching the design system's 'calm, not playful' motion rule."}, {"id": "context_translationprovider", "label": "TranslationProvider Interface", "file_type": "concept", "source_file": "context.md", "source_location": "L98", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "context_cloudtranslationprovider", "label": "cloudTranslationProvider.ts", "file_type": "code", "source_file": "context.md", "source_location": "L98", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "context_google_translate_endpoint", "label": "Unofficial Google Translate Endpoint", "file_type": "rationale", "source_file": "context.md", "source_location": "L98", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Unofficial, key-free translate.googleapis.com endpoint; works well but could break or rate-limit without warning \u2014 a paid API is the durable fallback if that happens."}, {"id": "context_cappolicy", "label": "capPolicy.ts Daily Translation Cap (20/day)", "file_type": "concept", "source_file": "context.md", "source_location": "L98", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "context_mlkit_translation", "label": "On-device ML Kit Translation (deferred)", "file_type": "concept", "source_file": "context.md", "source_location": "L98,L102", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "context_ispremiumuser", "label": "isPremiumUser() Stub", "file_type": "concept", "source_file": "context.md", "source_location": "L59,L98", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "context_milestone7", "label": "Milestone 7+ (Billing, ML Kit, Dev Client transition)", "file_type": "c