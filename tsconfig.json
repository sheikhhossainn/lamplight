{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    // scripts/sync-books.mjs imports textParser.ts with an explicit .ts
    // extension (required for a plain Node/tsx script) — needs this flag or
    // the editor's TS server flags it, even though it's valid at runtime.
    "allowImportingTsExtensions": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "scripts/**/*.mjs",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  // supabase/functions/** runs on Deno (Supabase Edge Functions), not Node —
  // `Deno` global and `npm:`/`https:` specifiers aren't resolvable here, same
  // reasoning as scripts/**/*.mjs being a separate Node-only runtime context.
  "exclude": [
    "supabase/functions/**"
  ]
}
